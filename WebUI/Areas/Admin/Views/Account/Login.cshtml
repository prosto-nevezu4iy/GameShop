@model WebUI.Areas.Admin.Models.LoginViewModel
@{
    ViewBag.Title = "Login";
    Layout = "~/Areas/Admin/Views/Shared/Login_Layout.cshtml";
}

<div class="container">
    <!-- Outer Row -->
    <div class="row justify-content-center">
        <div class="col-xl-10 mt-5 col-lg-12 col-md-9">
            <div class="card o-hidden border-0 shadow-lg my-5">
                <div class="card-body p-0">
                    <!-- Nested Row within Card Body -->
                    <div class="row">
                        <div class="col-lg-6 d-none d-lg-block bg-login-image"></div>
                        <div class="col-lg-6">
                            <div class="p-5">
                                <div class="text-center">
                                    <h1 class="h4 text-gray-900 mb-4">Welcome Back!</h1>
                                </div>
                                @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "user" }))
                                {
                                    @Html.AntiForgeryToken()

                                    <div class="form-group">
                                        @Html.TextBoxFor(u => u.Email, new { @class = "form-control form-control-user", placeholder = "Email" })
                                        @Html.ValidationMessageFor(u => u.Email)
                                    </div>
                                    <div class="form-group">
                                        @Html.PasswordFor(u => u.Password, new { @class = "form-control form-control-user", placeholder = "Password" })
                                        @Html.ValidationMessageFor(u => u.Password)
                                    </div>
                                    <div class="form-group">
                                        <div class="custom-control custom-checkbox small">
                                            @Html.CheckBoxFor(u => u.RememberMe, new { id = "customCheck", @class = "custom-control-input" })
                                            <label class="custom-control-label" for="customCheck">Remember Me</label>
                                        </div>
                                    </div>
                                    <input type="submit" class="btn btn-primary btn-user btn-block" value="Login" />
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>

</div>

