@model Core.Domain.Enums.Gender

@foreach (var value in Enum.GetValues(typeof(Core.Domain.Enums.Gender)))
{
    <label class="custom-control custom-radio custom-control-inline">
        @Html.RadioButtonFor(g => g, value, new { @class = "custom-control-input" })
        <span class="custom-control-label"> @value.ToString() </span>
    </label>
}
