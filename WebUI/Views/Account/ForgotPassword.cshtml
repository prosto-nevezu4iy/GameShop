@model WebUI.Models.ForgotPasswordViewModel
@{
    ViewBag.Title = "ForgotPassword";
}

<section class="section-conten padding-y" style="min-height:84vh">

    <!-- ============================ COMPONENT LOGIN   ================================= -->
    <div class="card mx-auto" style="max-width: 380px; margin-top:100px;">
        <div class="card-body">
            <h4 class="card-title mb-4">Forgot your password?</h4>
            <h6 class="card-title">Enter your email</h6>
            @Html.ValidationSummary()

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken();
                <div class="form-group">
                    @Html.TextBoxFor(u => u.Email, new { @class = "form-control", placeholder = "Email" })
                    @Html.ValidationMessageFor(u => u.Email)
                </div> <!-- form-group// -->
                <div class="form-group">
                    <button type="submit" class="btn btn-primary btn-block"> Email Link  </button>
                </div> <!-- form-group// -->
            }
        </div> <!-- card-body.// -->
    </div> <!-- card .// -->

    <p class="text-center mt-4">
        Don't have account?
        @Html.ActionLink("Sign up", "Register")
    </p>
    <br><br>
    <!-- ============================ COMPONENT LOGIN  END.// ================================= -->


</section>
<!-- ========================= SECTION CONTENT END// ========================= -->
