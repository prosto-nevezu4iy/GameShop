@model WebUI.Models.RegisterUserViewModel

@{
    ViewBag.Title = "Register User";
}

<!-- ========================= SECTION CONTENT ========================= -->
<section class="section-content padding-y">
    <!-- ============================ COMPONENT REGISTER   ================================= -->
    <div class="card mx-auto" style="max-width:520px; margin-top:40px;">
        <article class="card-body">
            <header class="mb-4"><h4 class="card-title">Sign up</h4></header>

            @Html.ValidationSummary()
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken();
                <div class="form-row">
                    <div class="col form-group">
                        @Html.LabelFor(u => u.FirstName)
                        @Html.TextBoxFor(u => u.FirstName, new { @class = "form-control" })
                        @Html.ValidationMessageFor(u => u.FirstName)
                    </div> <!-- form-group end.// -->
                    <div class="col form-group">
                        @Html.LabelFor(u => u.LastName)
                        @Html.TextBoxFor(u => u.LastName, new { @class = "form-control" })
                        @Html.ValidationMessageFor(u => u.LastName)
                    </div> <!-- form-group end.// -->
                </div> <!-- form-row end.// -->
                <div class="form-group">
                    @Html.LabelFor(u => u.Email)
                    @Html.TextBoxFor(u => u.Email, new { @class = "form-control" })
                    @Html.ValidationMessageFor(u => u.Email)
                    <small class="form-text text-muted">We'll never share your email with anyone else.</small>
                </div> <!-- form-group end.// -->
                <div class="form-group">
                    @Html.EditorFor(u => u.Gender)
                    @Html.ValidationMessageFor(u => u.Gender)
                </div>
                <div class="form-row">
                    <div class="form-group col-md-6">
                        @Html.LabelFor(u => u.Password)
                        @Html.PasswordFor(u => u.Password, new { @class = "form-control" })
                        @Html.ValidationMessageFor(u => u.Password)
                    </div> <!-- form-group end.// -->
                    <div class="form-group col-md-6">
                        @Html.LabelFor(u => u.PasswordConfirm)
                        @Html.PasswordFor(u => u.PasswordConfirm, new { @class = "form-control" })
                        @Html.ValidationMessageFor(u => u.PasswordConfirm)
                    </div> <!-- form-group end.// -->
                </div>
                <div class="form-group">
                    <button type="submit" class="btn btn-primary btn-block"> Register  </button>
                </div> <!-- form-group// -->
                <div class="form-group">
                    <label class="custom-control custom-checkbox">
                        @Html.CheckBoxFor(u => u.Terms, new { @class = "custom-control-input" })
                        <div class="custom-control-label">
                            I am agree with
                            <a href="#">terms and contitions</a>
                        </div>
                    </label>
                </div> <!-- form-group end.// -->
            }

        </article><!-- card-body.// -->
    </div> <!-- card .// -->
    <p class="text-center mt-4">
        Have an account?
        @Html.ActionLink("Log In", "Login")
    </p>
    <br><br>
    <!-- ============================ COMPONENT REGISTER  END.// ================================= -->
</section>
<!-- ========================= SECTION CONTENT END// ========================= -->
