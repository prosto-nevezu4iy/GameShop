@model WebUI.Models.AccountOverviewViewModel

@{
    ViewBag.Title = "Account";
}

<!-- ========================= SECTION PAGETOP ========================= -->
<section class="section-pagetop bg">
    <div class="container">
        <h2 class="title-page">My account</h2>
    </div> <!-- container //  -->
</section>
<!-- ========================= SECTION INTRO END// ========================= -->
<!-- ========================= SECTION CONTENT ========================= -->
<section class="section-content padding-y">
    <div class="container">

        <div class="row">
            <aside class="col-md-3">
                <ul class="list-group">
                    @Html.ActionLink("Account Overview", "Index", null, new { @class = "list-group-item active" })
                    @Html.ActionLink("Account Information", "Account", null, new { @class = "list-group-item" })
                    @Html.ActionLink("Change Password", "ChangePassword", null, new { @class = "list-group-item" })
                    @Html.ActionLink("Orders", "Orders", null, new { @class = "list-group-item" })
                </ul>
            </aside> <!-- col.// -->
            <main class="col-md-9">

                <article class="card mb-3">
                    <div class="card-body">

                        <figure class="icontext">
                            <div class="icon">
                                <img class="rounded-circle img-sm border" src="~/Content/images/avatars/avatar3.jpg">
                            </div>
                            <div class="text">
                                <strong> @Model.User.FirstName @Model.User.LastName </strong> <br>
                                @Model.User.Email <br>
                                <a href="#">Edit</a>
                            </div>
                        </figure>
                        <hr>

                        <article class="card-group">
                            <figure class="card bg">
                                <div class="p-3">
                                    <h5 class="card-title">@Model.OrdersCount</h5>
                                    <span>Orders</span>
                                </div>
                            </figure>
                            <figure class="card bg">
                                <div class="p-3">
                                    <h5 class="card-title">@Model.WishListCount</h5>
                                    <span>Wishlists</span>
                                </div>
                            </figure>
                            <figure class="card bg">
                                <div class="p-3">
                                    <h5 class="card-title">@Model.CartCount</h5>
                                    <span>Cart</span>
                                </div>
                            </figure>
                        </article>


                    </div> <!-- card-body .// -->
                </article> <!-- card.// -->

            </main> <!-- col.// -->
        </div>

    </div> <!-- container .//  -->
</section>
<!-- ========================= SECTION CONTENT END// ========================= -->
